#!/bin/bash
# Pre-commit hook for Rust code quality checks
# This hook runs cargo fmt and cargo clippy before allowing commits

set -e

# ANSI color codes for better output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
RESET='\033[0m'

# Check if we're in the right directory (should contain Cargo.toml)
if [ ! -f "Cargo.toml" ]; then
    echo -e "\n ${RED}Error: Cargo.toml not found. This hook should run in the Rust project root.${RESET}"
    exit 1
fi

# Function to print section headers
print_section() {
    echo -e "\n ${YELLOW}${BOLD}$1${RESET}"
}

# Check 1: Cargo fmt (formatting)
print_section "Checking code format.."
if cargo fmt -- --check; then
    echo -e " ${GREEN}• Pass${RESET}"
else
    echo -e " ${RED}• Fail${RESET}"
    echo -e " ${YELLOW}• Run 'cargo fmt' to fix formatting issues${RESET}"
    exit 1
fi

# Check 2: Cargo clippy (linting)
print_section "Checking lints..."
if cargo clippy -- -D warnings; then
    echo -e " ${GREEN}• Pass${RESET}"
else
    echo -e " ${RED}• Fail${RESET}"
    echo -e " ${YELLOW}• Fix the clippy issues above before committing${RESET}"
    exit 1
fi

# Check 3: Cargo check (compilation)
print_section "Checking compilation..."
if cargo check; then
    echo -e " ${GREEN}• Pass${RESET}"
else
    echo -e " ${RED}• Fail${RESET}"
    echo -e " ${YELLOW}• Fix compilation errors before committing${RESET}"
    exit 1
fi

# Check 4: Cargo test (unit and integration tests)
# Skip the UI build for tests; they only exercise Rust code and the
# Vite build is the slowest single step in `cargo test`.
print_section "Running Rust tests..."
if MEZAME_SKIP_UI_BUILD=1 cargo test --lib --tests; then
    echo -e " ${GREEN}• Pass${RESET}"
else
    echo -e " ${RED}• Fail${RESET}"
    echo -e " ${YELLOW}• Fix failing tests before committing${RESET}"
    exit 1
fi

# Check 5: UI lockfile sync. CI's `npm ci` refuses when
# `package-lock.json` does not agree with `package.json`. `npm ci
# --dry-run` does the same comparison locally without hitting the
# network or writing anything, so we surface drift before the push
# instead of letting CI catch it.
if [ -d "ui/node_modules" ]; then
    print_section "Checking UI lockfile sync..."
    if (cd ui && npm ci --dry-run --silent --no-audit --no-fund > /dev/null 2>&1); then
        echo -e " ${GREEN}• Pass${RESET}"
    else
        echo -e " ${RED}• Fail${RESET}"
        echo -e " ${YELLOW}• ui/package-lock.json and ui/package.json disagree.${RESET}"
        echo -e " ${YELLOW}• Run 'npm install' in ui/ to refresh the lockfile, then stage it.${RESET}"
        exit 1
    fi
fi

# Check 6: UI tests (Vitest). Skipped quietly when node_modules has not
# been installed yet (a fresh clone) so the hook does not block the
# very first commit on a new machine. Run `npm install` in `ui/` to
# enable.
if [ -d "ui/node_modules/vitest" ]; then
    print_section "Running UI tests..."
    # Vite's bare-import resolver only walks parent directories from
    # the importing file. Tests live at tests/ui/ which is outside
    # ui/, so we expose the package's node_modules via a symlink that
    # we recreate on every run. The symlink itself is gitignored.
    if [ ! -e "tests/ui/node_modules" ]; then
        ln -s ../../ui/node_modules tests/ui/node_modules
    fi
    if (cd ui && npm test --silent); then
        echo -e " ${GREEN}• Pass${RESET}"
    else
        echo -e " ${RED}• Fail${RESET}"
        echo -e " ${YELLOW}• Fix failing UI tests before committing${RESET}"
        exit 1
    fi
fi

# All checks passed
echo -e "\n ${GREEN}${BOLD}All checks passed! Ready to commit.${RESET}\n"
